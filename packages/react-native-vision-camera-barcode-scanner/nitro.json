{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["camera", "barcodescanner"],
  "ios": {
    "iosModuleName": "VisionCameraBarcodeScanner"
  },
  "android": {
    "androidNamespace": ["camera", "barcodescanner"],
    "androidCxxLibName": "VisionCameraBarcodeScanner"
  },
  "autolinking": {
    "BarcodeScannerFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridBarcodeScannerFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridBarcodeScannerFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}

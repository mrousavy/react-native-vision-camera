{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["camera", "textrecognition"],
  "ios": {
    "iosModuleName": "VisionCameraTextRecognition"
  },
  "android": {
    "androidNamespace": ["camera", "textrecognition"],
    "androidCxxLibName": "VisionCameraTextRecognition"
  },
  "autolinking": {
    "TextRecognizerFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTextRecognizerFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTextRecognizerFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}

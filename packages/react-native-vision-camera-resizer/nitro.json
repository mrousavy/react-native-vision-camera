{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["camera", "resizer"],
  "ios": {
    "iosModuleName": "VisionCameraResizer"
  },
  "android": {
    "androidNamespace": ["camera", "resizer"],
    "androidCxxLibName": "VisionCameraResizer"
  },
  "autolinking": {
    "ResizerFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridResizerFactory"
      },
      "android": {
        "language": "c++",
        "implementationClassName": "HybridResizerFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}

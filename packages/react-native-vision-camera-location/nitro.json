{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["camera", "location"],
  "ios": {
    "iosModuleName": "VisionCameraLocation"
  },
  "android": {
    "androidNamespace": ["camera", "location"],
    "androidCxxLibName": "VisionCameraLocation"
  },
  "autolinking": {
    "LocationManagerFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridLocationManagerFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridLocationManagerFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
